# ── Database ──
DATABASE_URI=postgresql://user:pass@host:5432/db

# ── Supabase Auth ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ── LLM ──
LLM_PROVIDER=google
GOOGLE_API_KEY=your-key
GEMINI_API_KEY=your-key  # alias for GOOGLE_API_KEY
ANTHROPIC_API_KEY=your-key  # if using Claude

# ── External APIs ──
GOOGLE_BOOKS_API_KEY=your-key
VOYAGE_API_KEY=pa-your-key
TAVILY_API_KEY=tvly-your-key

# ── Vector Store ──
QDRANT_URL=https://your-cluster.cloud.qdrant.io:6333
QDRANT_API_KEY=your-key

# ── Redis / Celery Broker ──
UPSTASH_REDIS_REST_URL=https://your-upstash-url
UPSTASH_REDIS_REST_TOKEN=your-token

# ── Reddit ──
REDDIT_CLIENT_ID=your-id
REDDIT_CLIENT_SECRET=your-secret

# ── Admin ──
ADMIN_USER_UUID=your-supabase-user-uuid

# ── CORS ──
FRONTEND_ORIGINS=http://localhost:3000 https://page-turner-seven.vercel.app
